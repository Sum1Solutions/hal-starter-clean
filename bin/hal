#!/usr/bin/env bash
# Stub CLI for HAL starter. Expand to integrate your chat backend.
set -e
CMD="$1"
shift || true
case "$CMD" in
  --warmup)
    echo "HAL Quick Digest (from HAL.md):"
    sed -n '1,40p' HAL.md
    ;;
  --chat)
    python3 bin/hal_chat.py "$@"
    ;;
  --drift-check)
    python3 tools/drift_check.py "$*"
    ;;
  *)
    echo "Usage: bin/hal --warmup | --chat \"prompt\" | --drift-check \"response\""
    ;;
esac
